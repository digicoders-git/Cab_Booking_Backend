		{
			"name": "04. Trip LifeCycle",
			"item": [
				{
					"name": "Get Pending Requests (Driver Polling)",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
						"url": { "raw": "http://localhost:5000/api/trips/requests/pending", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "trips", "requests", "pending"] }
					}
				},
				{
					"name": "Accept Ride Request",
					"request": {
						"method": "PUT",
						"header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"Accepted\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "http://localhost:5000/api/trips/requests/:requestId/respond", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "trips", "requests", ":requestId", "respond"] }
					}
				},
				{
					"name": "Start Trip (OTP Required)",
					"request": {
						"method": "PUT",
						"header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"otp\": \"1234\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "http://localhost:5000/api/trips/execute/:bookingId/start", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "trips", "execute", ":bookingId", "start"] }
					}
				},
				{
					"name": "End Trip (CASH or ONLINE)",
					"request": {
						"method": "PUT",
						"header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"paymentMethod\": \"Cash\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "http://localhost:5000/api/trips/execute/:bookingId/end", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "trips", "execute", ":bookingId", "end"] }
					}
				}
			]
		},
