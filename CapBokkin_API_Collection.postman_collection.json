{
  "info": {
    "name": "CapBokkin - Complete API Collection",
    "_postman_id": "capbokkin-complete-2026",
    "description": "CapBokkin Cab Booking Backend - Saari APIs ka complete Postman Collection.\n\n🔐 Auth Flow:\n1. Admin Login karo → Token copy karo → adminToken variable mein daalo\n2. Fleet Login karo → Token copy karo → fleetToken variable mein daalo\n3. Driver Login karo → Token copy karo → driverToken variable mein daalo\n4. Agent Login karo → Token copy karo → agentToken variable mein daalo\n\n📌 Variables:\n- baseUrl: http://localhost:5000\n- adminToken: (Admin login ke baad milega)\n- fleetToken: (Fleet login ke baad milega)\n- driverToken: (Driver login ke baad milega)\n- agentToken: (Agent login ke baad milega)\n- driverId, carId, fleetDriverId, assignmentId, etc.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000", "type": "string" },
    { "key": "adminToken",   "value": "", "type": "string" },
    { "key": "fleetToken",   "value": "", "type": "string" },
    { "key": "driverToken",  "value": "", "type": "string" },
    { "key": "agentToken",   "value": "", "type": "string" },
    { "key": "driverId",     "value": "", "type": "string" },
    { "key": "userId",       "value": "", "type": "string" },
    { "key": "agentId",      "value": "", "type": "string" },
    { "key": "fleetId",      "value": "", "type": "string" },
    { "key": "fleetDriverId","value": "", "type": "string" },
    { "key": "carId",        "value": "", "type": "string" },
    { "key": "assignmentId", "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🛡️ ADMIN APIs",
      "item": [
        {
          "name": "1. Admin Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/admin/register", "host": ["{{baseUrl}}"], "path": ["api","admin","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Super Admin\",\n  \"email\": \"admin@capbokkin.com\",\n  \"password\": \"admin@123\"\n}"
            }
          }
        },
        {
          "name": "2. Admin Login → Token Copy Karo",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/admin/login", "host": ["{{baseUrl}}"], "path": ["api","admin","login"] },
